{
  "name": "wp-music-control",
  "version": "1.0.0",
  "description": "Powerful Gutenberg blog that allows adding photo galleries with music and animations.",
  "scripts": {
    "build:app": "wp-scripts build src/block/index.js src/block/view.js --output-path=build",
    "build:free": "wp-scripts build src/free/themes/*.js src/free/overlay-animations/*.js src/free/background-animations/*.js --output-path=build/free",
    "build:pro": "wp-scripts build src/pro/themes/*.scss src/pro/overlay-animations/*.js src/pro/background-animations/*.js --output-path=build/pro",
    "build": "yarn build:app && yarn build:free && yarn build:pro",
    "format": "wp-scripts format",
    "lint:css": "wp-scripts lint-style",
    "lint:js": "wp-scripts lint-js",
    "packages-update": "wp-scripts packages-update",
    "plugin-zip": "wp-scripts plugin-zip",
    "start": "wp-scripts start --blocks-manifest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Miro0/wp-music-gallery.git"
  },
  "keywords": [
    "wp",
    "music",
    "gallery",
    "photo",
    "slider",
    "swiper",
    "music",
    "background"
  ],
  "author": "Beed Vision",
  "license": "ISC",
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
  "dependencies": {
    "@wordpress/block-editor": "^15.7.0",
    "@wordpress/blocks": "^15.7.0",
    "@wordpress/components": "^30.7.0",
    "@wordpress/element": "^6.35.0",
    "@wordpress/i18n": "^6.7.0",
    "@wordpress/scripts": "^30.27.0",
    "swiper": "^12.0.3"
  }
}
