{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "beedvision/wp-music-gallery",
	"version": "1.0.0",
	"title": "WP Music Gallery",
	"category": "widgets",
	"description": "Powerful Gutenberg block that allows adding photo galleries with music and animations.",
	"attributes": {
		"photos": {
			"type": "array"
		},
		"music": {
			"type": "object"
		},
		"theme": {
			"type": "string",
			"default": "default"
		},
		"slides_duration": {
			"type": "number",
			"default": 2
		},
		"background_animation": {
			"type": "string"
		},
		"background_animation_options": {
			"type": "object"
		},
		"overlay_animation": {
			"type": "string"
		},
		"overlay_animation_options": {
			"type": "object"
		}
	},
	"example": {},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ]
	},
	"textdomain": "wpmusicgallery",
	"editorScript": "file:./index.js",
	"viewScript": "file:./view.js"
}
