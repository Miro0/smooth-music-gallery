{
  "name": "music-control",
  "version": "1.0.1",
  "description": "Powerful Gutenberg block for photo galleries with music and animations, plus a built-in Shortcode Builder.",
  "scripts": {
    "build:app": "wp-scripts build src/block/index.js src/block/view.js --output-path=build",
    "build:core": "wp-scripts build src/smooth-music-gallery.js --output-path=build/core",
    "build:backgrounds": "wp-scripts build src/backgrounds/*.js --output-path=build/background",
    "build:overlays": "wp-scripts build src/overlays/*.js --output-path=build/overlay",
    "build:themes": "wp-scripts build src/themes/*.js --output-path=build/theme",
    "build:shortcode_builder": "wp-scripts build src/block/shortcode_builder.js --output-path=build/admin",
    "build": "yarn build:app && yarn build:core && yarn build:backgrounds && yarn build:overlays && yarn build:themes && yarn build:shortcode_builder",
    "zip:prod": "yarn build && bash scripts/create-prod-zip.sh",
    "zip:prod:only": "bash scripts/create-prod-zip.sh",
    "release:prepare": "bash scripts/prepare-release.sh",
    "format": "wp-scripts format",
    "lint:css": "wp-scripts lint-style",
    "lint:js": "wp-scripts lint-js",
    "packages-update": "wp-scripts packages-update",
    "start": "wp-scripts start --blocks-manifest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Miro0/smooth-music-gallery.git"
  },
  "keywords": [
    "wp",
    "music",
    "gallery",
    "photo",
    "slider",
    "swiper",
    "music",
    "background"
  ],
  "author": "Smooth CDN",
  "license": "ISC",
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
  "dependencies": {
    "@smoothcdn/asset-picker": "^1.0.8",
    "@wordpress/block-editor": "^15.7.0",
    "@wordpress/blocks": "^15.7.0",
    "@wordpress/components": "^30.7.0",
    "@wordpress/element": "^6.35.0",
    "@wordpress/i18n": "^6.7.0",
    "@wordpress/scripts": "^30.27.0",
    "swiper": "^12.1.2"
  }
}
