{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "beedvision/music-gallery",
	"version": "1.0.0",
	"title": "Music Gallery",
	"category": "widgets",
	"description": "Powerful Gutenberg block that allows adding photo galleries with music and animations.",
	"attributes": {
		"photos": {
			"type": "array"
		},
		"photos_cdn": {
			"type": "array"
		},
		"music": {
			"type": "object"
		},
		"music_cdn": {
			"type": "object"
		},
		"photos_source": {
			"type": "string",
			"default": "wp"
		},
		"music_source": {
			"type": "string",
			"default": "wp"
		},
		"theme": {
			"type": "string",
			"default": "default"
		},
		"theme_options": {
			"type": "object"
		},
		"size": {
			"type": "number"
		},
		"slides_duration": {
			"type": "number",
			"default": 2
		},
		"background": {
			"type": "string"
		},
		"background_options": {
			"type": "object"
		},
		"overlay": {
			"type": "string"
		},
		"overlay_options": {
			"type": "object"
		}
	},
	"example": {},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ]
	},
	"textdomain": "musicgallery",
	"editorScript": "file:./index.js",
	"editorStyle": "mg-editor"
}
